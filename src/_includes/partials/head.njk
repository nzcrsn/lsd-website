<head>
  <meta charset="UTF-8" />
  <meta http-equiv="content-language" content="{{ t.locale }}" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0 viewport-fit=cover"
  />

  <title>{{ t.pages[pageKey].title }}</title>
  <meta name="description" content="{{ t.pages[pageKey].description }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ t.pages[pageKey].title }}" />
  <meta
    property="og:description"
    content="{{ t.pages[pageKey].description }}"
  />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Lift Service Déménagement" />

  <!-- Canonical -->

  <link
    rel="canonical"
    href="https://www.liftservicebel.com{{ t.routes[pageKey] }}"
  />

  <link
    rel="alternate"
    hreflang="fr-be"
    href="https://www.liftservicebel.com{{ t.routes[pageKey] }}"
  />

  <link
    rel="alternate"
    hreflang="es-es"
    href="https://www.liftservicebel.com{{ i18n.es.routes[pageKey] }}"
  />
  <link
    rel="alternate"
    hreflang="en-gb"
    href="https://www.liftservicebel.com{{ i18n.en.routes[pageKey] }}"
  />

  <link
    rel="alternate"
    hreflang="x-default"
    href="https://www.liftservicebel.com{{ t.routes[pageKey] }}"
  />

  <!-- Icons -->
  <link
    rel="apple-touch-icon"
    sizes="180x180"
    href="assets/images/favicon/apple-touch-icon.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href="assets/images/favicon/favicon-32x32.png"
  />
  <!-- !! Inline — fires before first paint, no flash !! -->
  <style>
    #page,
    header {
      opacity: 0;
    }
  </style>
  <script>
    document.documentElement.className += " js-loading";
  </script>
  <!-- Core CSS -->
  <link rel="stylesheet" href="/assets/css/core/font-family.css" />
  <link rel="stylesheet" href="/assets/css/core/normalize.css" />
  <link rel="stylesheet" href="/assets/css/core/lenis.css" />
  <link rel="stylesheet" href="/assets/css/core/global.css" />
  <link rel="stylesheet" href="/assets/css/core/layout.css" />
  <!-- <link rel="stylesheet" href="/assets/css/components/loader.css" /> -->
  <link rel="stylesheet" href="/assets/css/components/menu.css" />
  <link rel="stylesheet" href="/assets/css/components/header.css" />
  <link rel="stylesheet" href="/assets/css/components/footer.css" />
  <!-- <link rel="stylesheet" href="/assets/css/pages/home.css" /> -->

  <!-- Page-specific CSS -->
  {% if stylesheet %}
  <link rel="stylesheet" href="/assets/css/pages/{{ stylesheet }}" />
  {% endif %}

  <!-- Google Tag Manager -->
  <script>
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != "dataLayer" ? "&l=" + l : "";
      j.async = true;
      j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, "script", "dataLayer", "GTM-PJ9KFKG2");
  </script>
  <!-- End Google Tag Manager -->
</head>
