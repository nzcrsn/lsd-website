  <div class="loader-panel" id="panelBottom"></div>
</div>

<div class="loader-brand" id="loaderBrand" aria-hidden="true">
  <div class="loader-wordmark">
    <div class="loader-name-top">
      <span class="loader-word" id="wordLift">Lift</span>&nbsp;<span
        class="loader-word"
        id="wordService"
        >Service</span
      >
    </div>
    <div class="loader-name-bottom">
      <span class="loader-word" id="wordDemenagement">Déménagement</span>
    </div>
