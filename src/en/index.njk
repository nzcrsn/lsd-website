---
layout: layouts/base.njk
lang: en
pageKey: home
stylesheet: home.css
---

{% set t = i18n[lang] %}
<!-- Start Hero section -->
<section id="hero" class="hero-section">
  <div class="copy">
    <h1 class="heading">{{ t.section.hero.heading}}</h1>
    <p class="sub-heading">
      Furniture lifts, equipped lorries and qualified personnel to make
      everything easier.
    </p>

    <div class="hero-trust">
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat__number">+10</span>
          <span class="hero-stat__label"
            >{{t.section.hero.year_experiencie_lbl}}</span
          >
        </div>

        <div class="hero-stat">
          <span class="hero-stat__number">+5 000</span>
          <span class="hero-stat__label"
            >{{t.section.hero.clientes_satisf_lbl}}</span
          >
        </div>

        <div class="hero-stat">
          <span class="hero-stat__number">+6</span>
          <span class="hero-stat__label"
            >{{t.section.hero.countries_cover_lbl}}</span
          >
        </div>
      </div>
    </div>

    <a class="cta-btn cta-heading">
      <p>Request a quote</p>
      <svg
        class="arrow"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M7 17L17 7M17 7H8M17 7V16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
    <div class="proof__badges">
      <span class="proof__badge">
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        Response within 24 hours
      </span>
    </div>

    <div class="proof" id="proof">
      <div class="proof__rating">
        <div class="proof__stars">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
        </div>
        <span class="proof__score">4.9</span>
        <span class="proof__source"> in Google </span>
        <span class="proof__count">81 verified reviews</span>
      </div>
    </div>
  </div>

  <div class="grid">
    <div class="item video tall">
      <video
        src="/assets/videos/v4-n.mp4"
        autoplay
        muted
        playsinline
        loop
        preload="metadata"
      ></video>
    </div>
    <div class="item">
      <img src="/assets/images/img-8.webp" alt="" />
    </div>

    <div class="item medium">
      <img src="../assets/images/lift-employee.webp" alt="" />
    </div>
  </div>
</section>
<!-- End of hero section -->

<!-- Start services section -->
<section id="services" class="services-section">
  <div class="eyebrow">Our services</div>
  <h2>Tailored to you, designed for you.</h2>

  <div class="services-bento__layout">
    <!-- 01 — Monte-meubles (hero) -->
    <div class="svc-tile svc-tile--lift">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">01</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Furniture lift hire</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Rental of motorised lifts for furniture and heavy or bulky materials.
          bulky.
        </p>
      </div>
    </div>

    <!-- 02 — Camions -->
    <div class="svc-tile svc-tile--trucks">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">02</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Equipped lorries + driver</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Trucks equipped with experienced drivers for safe, practical, and
          professional transport.
        </p>
      </div>
    </div>

    <!-- 03 — Déménagement -->
    <div class="svc-tile svc-tile--move">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">03</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Removals tailored <br />to your needs</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Support from start to finish, designed to suit your situation, with no
          stress or surprises.
        </p>
      </div>
    </div>

    <!-- 04 — Fournitures (wide) -->
    <div class="svc-tile svc-tile--supply">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">04</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Moving supplies</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Boxes, straps, bubble wrap and protective materials delivered to your
          home so you can pack your belongings in complete safety.
        </p>
      </div>
    </div>
  </div>

  <div class="cta-services">
    <p>Ready to move?</p>
    <a class="cta-btn">
      <p>Request a quote</p>
      <svg
        class="arrow"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M7 17L17 7M17 7H8M17 7V16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>
</section>
<!-- End services section -->
