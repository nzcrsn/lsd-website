      <!-- The form -->
      <div class="contact-form-wrap" id="formWrap">
        <p class="form__title">
          Explíquenos sus necesidades y nosotros nos encargaremos del resto.
        </p>

        <!--
          Netlify form attributes:
          - name="contact" → Netlify identifies this form
          - netlify → enables Netlify Forms
          - netlify-honeypot="bot-field" → spam protection
        -->
        <form
          class="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          id="contactForm"
          novalidate
        >
          <!-- Honeypot (hidden from real users) -->
          <p hidden>
            <label>No rellenar: <input name="bot-field" /></label>
          </p>

          <!-- Row: name + email -->
          <div class="form-row">
            <div class="form-field">
              <label for="sender_name">Su nombre</label>
              <input
                type="text"
                id="sender_name"
                name="sender_name"
                placeholder="Jean Dupont"
                autocomplete="name"
                required
              />
            </div>
            <div class="form-field">
              <label for="sender_email">Tu correo electrónico</label>
              <input
                type="email"
                id="sender_email"
                name="sender_email"
                placeholder="jean@exemple.com"
                autocomplete="email"
                required
              />
            </div>
          </div>

          <!-- Service selector as pills -->
          <div class="form-field">
            <label>Tipo de servicio</label>
            <div
              class="service-pills"
              role="group"
              aria-label="Choisissez un service"
            >
              <label class="pill-label">
                <input
                  type="radio"
                  name="service"
                  value="monte-meubles"
                  required
                />
                <span class="pill">Elevador de muebles</span>
              </label>

              <label class="pill-label">
                <input type="radio" name="service" value="camion-chauffeur" />
                <span class="pill">Camión + conductor</span>
              </label>

              <label class="pill-label">
                <input
                  type="radio"
                  name="service"
                  value="demenagement-mesure"
                />
                <span class="pill">Mudanza a medida</span>
              </label>

              <label class="pill-label">
                <input type="radio" name="service" value="fournitures" />
                <span class="pill">Suministros de mudanza</span>
              </label>
            </div>
          </div>

          <!-- Message -->
          <div class="form-field">
            <label for="message">Tu mensaje</label>
            <textarea
              id="message"
              name="message"
              placeholder="Décrivez votre déménagement — adresses, étages, date souhaitée…"
              required
            ></textarea>
          </div>

          <button class="cta-btn cta-form" type="submit">
            <p>Enviar el mensaje</p>
            <svg
