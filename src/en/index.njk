    </li>

    <li class="faq__item">
      <h3>
        <button class="faq__trigger" aria-expanded="false">
          <div class="faq__question-wrap">
            <span class="faq__index">02</span>
            <span class="faq__question"
              >¿Puedo reservar para un sábado o un día festivo?</span
