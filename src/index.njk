<!-- Start services section -->
<section id="services" class="services-section">
  <div class="eyebrow">Nos services</div>
  <h2>Adaptés à vous, conçus pour vous.</h2>

  <div class="services-bento__layout">
    <!-- 01 — Monte-meubles (hero) -->
    <div class="svc-tile svc-tile--lift">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">01</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Location de<br />monte-meubles</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Élévateurs motorisés pour meubles et matériaux lourds — discrets,
          efficaces, livrés chez vous.
        </p>
      </div>
    </div>

    <!-- 02 — Camions -->
    <div class="svc-tile svc-tile--trucks">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">02</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Camions + chauffeur</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Véhicules avec chauffeur expérimenté — sûr, pratique, ponctuel.
        </p>
      </div>
    </div>

    <!-- 03 — Déménagement -->
    <div class="svc-tile svc-tile--move">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">03</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Déménagement<br />sur mesure</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          De A à Z, adapté à votre situation — sans surprise.
        </p>
      </div>
    </div>

    <!-- 04 — Fournitures (wide) -->
    <div class="svc-tile svc-tile--supply">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">04</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Matériaux d' emballage</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Boîtes, sangles, bulles et protections livrées à domicile.
        </p>
      </div>
    </div>
  </div>

  <div class="cta-services">
    <p>Prêt à déménager ?</p>
    <a class="cta-btn">
      <p>Demander un devis</p>
      <svg
        class="arrow"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M7 17L17 7M17 7H8M17 7V16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>
</section>
<!-- End services section -->
