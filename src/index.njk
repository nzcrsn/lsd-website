          x="12"
          y="24"
          width="28"
          height="20"
          rx="1"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <!-- Door -->
        <rect
          x="21"
          y="34"
          width="10"
          height="10"
          rx="1"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <!-- Door knob -->
        <circle cx="29" cy="39" r="1" fill="currentColor" opacity="0.6" />
        <!-- Window -->
        <rect
          x="15"
          y="28"
          width="7"
          height="6"
          rx="0.5"
          stroke="currentColor"
          stroke-width="1.4"
        />
        <!-- Window cross -->
        <line
          x1="18.5"
          y1="28"
          x2="18.5"
          y2="34"
          stroke="currentColor"
          stroke-width="1"
        />
        <line
          x1="15"
          y1="31"
          x2="22"
          y2="31"
          stroke="currentColor"
          stroke-width="1"
        />
        <!-- Checkmark badge top-right -->
        <circle cx="40" cy="14" r="6" fill="currentColor" opacity="0.12" />
        <path
          d="M37 14 L39.5 16.5 L43 12"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <p class="service-card__title">Déménagement sur mesure</p>
      <p class="service-card__desc">
        Un accompagnement de A à Z conçu pour s'adapter à votre situation, sans
        stress ni surprise.
      </p>
    </article>

    <!-- 04 — Fournitures -->
    <article class="service-card">
      <svg
        class="service-card__icon"
        viewBox="0 0 52 52"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <!-- Main box -->
        <rect
          x="10"
          y="22"
          width="32"
          height="24"
          rx="1.5"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <!-- Box top flaps open -->
        <path
          d="M10 22 L18 14 L34 14 L42 22"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linejoin="round"
        />
        <!-- Left flap -->
        <line
          x1="10"
          y1="22"
          x2="18"
          y2="14"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
        <!-- Right flap -->
        <line
          x1="42"
          y1="22"
          x2="34"
          y2="14"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
        <!-- Center flap divider -->
        <line
          x1="26"
          y1="14"
          x2="26"
          y2="22"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <!-- Tape strip on front -->
        <line
          x1="26"
          y1="22"
          x2="26"
          y2="46"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-dasharray="3 2"
          opacity="0.5"
        />
        <!-- Horizontal tape -->
        <line
          x1="10"
          y1="34"
          x2="42"
          y2="34"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-dasharray="3 2"
          opacity="0.5"
        />
        <!-- Bubble wrap dots suggestion -->
        <circle cx="17" cy="28" r="1.2" fill="currentColor" opacity="0.3" />
        <circle cx="22" cy="28" r="1.2" fill="currentColor" opacity="0.3" />
        <circle cx="17" cy="33" r="1.2" fill="currentColor" opacity="0.3" />
      </svg>
      <p class="service-card__title">Fournitures de déménagement</p>
      <p class="service-card__desc">
        Boîtes, sangles, bulles et protections livrées à domicile pour emballer
        vos biens en toute sécurité.
      </p>
    </article>
  </div>
</section>
<!-- End services section -->
