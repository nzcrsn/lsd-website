<!-- Start services section -->
<section id="services" class="services-section">
  <div class="eyebrow">Nos services</div>
  <h2>Adaptés à vous, conçus pour vous.</h2>
  <div class="services-cards">
    <!-- 01 — Monte-meubles -->
    <article class="service-card" id="first-service">
      <svg
        class="service-card__icon"
        viewBox="0 0 52 52"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <!-- Building outline -->
        <rect
          x="8"
          y="28"
          width="14"
          height="18"
          rx="1"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <!-- Window on building -->
        <rect
          x="12"
          y="32"
          width="4"
          height="4"
          rx="0.5"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <!-- Elevator mast vertical -->
        <line
          x1="26"
          y1="8"
          x2="26"
          y2="46"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
        <!-- Mast support arm -->
        <line
          x1="26"
          y1="10"
          x2="36"
          y2="10"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
        <!-- Pulley circle -->
        <circle
          cx="36"
          cy="10"
          r="2.5"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <!-- Cable going down -->
        <line
          x1="36"
          y1="12.5"
          x2="36"
          y2="30"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-dasharray="2 2"
        />
        <!-- Platform / load box -->
        <rect
          x="30"
          y="30"
          width="12"
          height="9"
          rx="1"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <!-- Box lines suggesting furniture -->
        <line
          x1="30"
          y1="34"
          x2="42"
          y2="34"
          stroke="currentColor"
          stroke-width="1.2"
        />
      </svg>
      <p class="service-card__title">Location de monte-meubles</p>
      <p class="service-card__desc">
        Location d'élévateurs motorisés pour meubles et matériaux lourds ou
        encombrants, sans effort et en toute sécurité.
      </p>
    </article>

    <!-- 02 — Camions -->
    <article class="service-card" id="second-service">
      <svg
        class="service-card__icon"
        viewBox="0 0 52 52"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <!-- Truck body -->
        <rect
          x="4"
          y="20"
          width="28"
          height="18"
          rx="1.5"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <!-- Truck cab -->
        <path
          d="M32 30 L32 22 L44 22 L46 27 L46 38 L32 38"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linejoin="round"
        />
        <!-- Cab window -->
        <path
          d="M34 22 L34 28 L44 28"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linejoin="round"
        />
        <!-- Front wheel -->
        <circle
          cx="38"
          cy="40"
          r="4"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <circle cx="38" cy="40" r="1.5" fill="currentColor" opacity="0.4" />
        <!-- Rear wheel -->
        <circle
          cx="14"
          cy="40"
          r="4"
          stroke="currentColor"
          stroke-width="1.8"
        />
        <circle cx="14" cy="40" r="1.5" fill="currentColor" opacity="0.4" />
        <!-- Cargo lines -->
        <line
          x1="10"
          y1="26"
          x2="10"
          y2="36"
          stroke="currentColor"
          stroke-width="1.2"
          opacity="0.5"
        />
        <line
          x1="18"
          y1="26"
          x2="18"
          y2="36"
          stroke="currentColor"
          stroke-width="1.2"
          opacity="0.5"
        />
        <line
          x1="26"
          y1="26"
          x2="26"
          y2="36"
          stroke="currentColor"
          stroke-width="1.2"
          opacity="0.5"
