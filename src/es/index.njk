---
layout: layouts/base.njk
lang: es
pageKey: home
stylesheet: home.css
---

{% set t = i18n[lang] %}

<!-- Start Hero section -->
<section id="hero" class="hero-section">
  <div class="copy">
    <h1 class="heading">Mudarte debería ser emocionante, no estresante</h1>
    <p class="sub-heading">
      Elevadores de mudanza, camiones equipados y personal cualificado para que
      todo sea más fácil.
    </p>

    <div class="hero-trust">
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat__number">10+</span>
          <span class="hero-stat__label">años de experiencia</span>
        </div>

        <div class="hero-stat">
          <span class="hero-stat__number">5,000+</span>
          <span class="hero-stat__label">clientes satisfechos</span>
        </div>

        <div class="hero-stat">
          <span class="hero-stat__number">6 </span>
          <span class="hero-stat__label">paises cubiertos</span>
        </div>
      </div>
    </div>

    <a class="cta-btn cta-heading">
      <p>Solicitar presupuesto</p>
      <svg
        class="arrow"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M7 17L17 7M17 7H8M17 7V16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
    <div class="proof__badges">
      <span class="proof__badge">
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        Respuesta en 24 horas
      </span>
    </div>

    <div class="proof" id="proof">
      <div class="proof__rating">
        <div class="proof__stars">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            />
          </svg>
        </div>
        <span class="proof__score">4.9</span>
        <span class="proof__source"> en Google </span>
        <span class="proof__count">81 opiniones verificadas</span>
      </div>
    </div>
  </div>

  <div class="grid">
    <div class="item video tall">
      <video
        src="/assets/videos/v4-n.mp4"
        autoplay
        muted
        playsinline
        loop
      ></video>
    </div>
    <div class="item">
      <img src="/assets/images/img-8.webp" alt="" />
    </div>

    <div class="item medium">
      <img src="../assets/images/lift-employee.webp" alt="" />
    </div>
  </div>
</section>
<!-- End of hero section -->

<!-- Start services section -->
<section id="services" class="services-section">
  <div class="eyebrow">Nuestros servicios</div>
  <h2>Adaptados a ti, diseñados para ti.</h2>

  <div class="services-bento__layout">
    <!-- 01 — Monte-meubles (hero) -->
    <div class="svc-tile svc-tile--lift">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">01</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">
          Alquiler de elevadores<br />
          de muebles
        </h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Alquiler de elevadores motorizados para muebles y materiales pesados o
          voluminosos.
        </p>
      </div>
    </div>

    <!-- 02 — Camions -->
    <div class="svc-tile svc-tile--trucks">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">02</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Camiones equipados + conductor</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Camiones equipados con conductores experimentados para un transporte
          seguro, práctico y profesional.
        </p>
      </div>
    </div>

    <!-- 03 — Déménagement -->
    <div class="svc-tile svc-tile--move">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">03</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Mudanzas<br />a tu medida</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Un acompañamiento de principio a fin diseñado para adaptarse a su
          situación, sin estrés ni sorpresas.
        </p>
      </div>
    </div>

    <!-- 04 — Fournitures (wide) -->
    <div class="svc-tile svc-tile--supply">
      <div class="svc-tile__photo"></div>
      <div class="svc-tile__overlay"></div>
      <span class="svc-tile__num">04</span>
      <div class="svc-tile__bracket"></div>
      <div class="svc-tile__content">
        <h3 class="svc-tile__title">Materiales para mudanzas</h3>
        <div class="svc-tile__divider"></div>
        <p class="svc-tile__desc">
          Cajas, correas, plástico de burbujas y protecciones entregadas a
          domicilio para embalar sus pertenencias con total seguridad.
        </p>
      </div>
    </div>
  </div>

  <div class="cta-services">
    <p>¿Listo para mudarte?</p>
    <a class="cta-btn">
      <p>Solicitar un presupuesto</p>
      <svg
        class="arrow"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M7 17L17 7M17 7H8M17 7V16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>
</section>
<!-- End services section -->
