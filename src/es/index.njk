          Netlify form attributes:
          - name="contact" → Netlify identifies this form
          - netlify → enables Netlify Forms
          - netlify-honeypot="bot-field" → spam protection
        -->
        <form
          class="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          id="contactForm"
          novalidate
        >
          <!-- Honeypot (hidden from real users) -->
          <p hidden>
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>

          <!-- Row: name + email -->
          <div class="form-row">
            <div class="form-field">
              <label for="sender_name">Votre nom</label>
              <input
                type="text"
                id="sender_name"
                name="sender_name"
